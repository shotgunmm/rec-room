- let siteBranch = 'REC ROOM';
- let pageName = 'Contact';
- let subPage = '';
- let pageTitle = pageName + ' | ' + siteBranch

include ../partials/head.pug
include ../partials/header.pug
include ../layouts/pageTitle.pug
include ../layouts/formFields.pug
include ../partials/footer.pug

doctype html
html(lang='en')
    +head(pageTitle)

    body.loading
        +header()

        +pageTitle()

        section.contact-row.pb-5.mb-5
            .container.narrow
                .row
                    .col-md-5
                        h2.text-uppercase.mb-1 Rec Room
                        p 637 Washington St, Hanover, MA 02339#[br] Located in Starland Sportsplex & Fun Park#[br] (781) 996-3054
                        .map.d-block.d-md-inline-flex
                            .map-size
                                img(src='images/map-size.jpg', alt='')
                            iframe.gmap(src='https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2959.2399828418934!2d-70.8277102578408!3d42.12374542938569!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e49f9d29fc85cf%3A0x20a6f9d39e57cd85!2sRec%20Room!5e0!3m2!1sen!2sin!4v1738946745260!5m2!1sen!2sin', width='600', height='450', style='border:0;', allowfullscreen='', loading='lazy', referrerpolicy='no-referrer-when-downgrade')

                    .col-md-7.mt-4.mt-5
                        form.row.contact-form(action='')
                            +inputField('Your Name (required)', 'text', 'Name')
                            +inputField('Your Email (required)', 'email', 'email')
                            +inputField('Your Phone Number (required)', 'tel', 'phone')
                            +inputField('Subject', 'text', 'subject')
                            +inputTextA('Message', 'subject')
                            .col-12.text-center.mt-4.pt-3
                                +buttonForm('Submit')

        +footer()